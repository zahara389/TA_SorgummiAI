    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.0.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "exceljs": "^4.3.0",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.4.15",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "mysql2": "^3.22.5",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
